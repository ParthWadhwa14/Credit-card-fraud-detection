# Keep full datasets ignored
data/raw/*
# Ignore processed data by default
data/processed/*

# But keep processed test data for Streamlit demo
!data/processed/X_test.csv
!data/processed/y_test.csv

# Keep test fixtures tracked for CI
!tests/
!tests/fixtures/
!tests/fixtures/X_test_sample.csv
!tests/fixtures/y_test_sample.csv

# Keep only deployment artifacts tracked
models/*
!models/tuned_xgboost_weighted.pkl
!models/scaler.pkl

reports/*
!reports/xgboost_champion_config.json
!reports/xgboost_champion_test_metrics.json